{
  "name": "rubber-duck-debugger",
  "version": "0.3.0",
  "description": "바탕화면 러버덕 디버깅 위젯 — 클릭하면 꽥! 이미지·소리·문구 커스텀.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/skins.test.js",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rubberduck.debugger",
    "productName": "RubberDuckDebugger",
    "artifactName": "${productName}-Setup.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.6.0"
  }
}
